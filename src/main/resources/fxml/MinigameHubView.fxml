<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<!-- 
    Vault-Tec View: Minigame Hub
    Main menu displaying all available minigames in a flow layout
    S.P.E.C.I.A.L. Stats: Charisma (welcoming design), Intelligence (organization)
-->
<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17"
            fx:controller="dev.skypaolo.controller.MinigameHubController"
            styleClass="vault-background"
            prefWidth="800"
            prefHeight="600">
    
    <!-- Header Section -->
    <top>
        <VBox styleClass="hub-header" spacing="10" alignment="CENTER">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            
            <!-- Vault-Tec Logo Area -->
            <HBox alignment="CENTER" spacing="15">
                <Label styleClass="vault-logo-icon" text="VT"/>
                <VBox alignment="CENTER_LEFT">
                    <Label styleClass="hub-title" text="VAULT-TEC INDUSTRIES"/>
                    <Label styleClass="hub-subtitle" text="MINI GAME HUB"/>
                </VBox>
            </HBox>
            
            <!-- Welcome Message -->
            <Label styleClass="hub-welcome" 
                   text="Welcome, Overseer! Select a simulation to begin training."
                   wrapText="true"
                   textAlignment="CENTER"/>
            
            <!-- Separator -->
            <Separator styleClass="vault-separator"/>
        </VBox>
    </top>
    
    <!-- Main Content: Minigame Cards Flow Layout -->
    <center>
        <ScrollPane styleClass="vault-scroll-pane" 
                    fitToWidth="true"
                    fitToHeight="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED">
            
            <content>
                <FlowPane fx:id="cardsContainer"
                          styleClass="cards-flow-container"
                          hgap="20"
                          vgap="20"
                          alignment="CENTER">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>
                    
                    <!-- Cards will be dynamically added here by the controller -->
                    
                </FlowPane>
            </content>
            
        </ScrollPane>
    </center>
    
    <!-- Footer Section -->
    <bottom>
        <VBox styleClass="hub-footer" alignment="CENTER">
            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>
            
            <Label styleClass="footer-text" 
                   text="Vault-Tec is not responsible for any unforeseen data corruption, ghoulification, or existential dread."
                   wrapText="true"
                   textAlignment="CENTER"/>
            
            <Label styleClass="footer-version" text="VT-OS v84.2.39 | Mini Game Hub v1.0"/>
        </VBox>
    </bottom>
    
</BorderPane>
